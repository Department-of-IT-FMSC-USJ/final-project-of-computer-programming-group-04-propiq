def save_uploaded_image(uploaded_file, dest_path: str) -> bool:
    """
    Saves any uploaded image (jpg/png) as a proper JPEG file on disk.
    Converts PNG with alpha to RGB to ensure fpdf compatibility.
    Returns True on success.
    """
    try:
        from PIL import Image as PILImage
        img = PILImage.open(uploaded_file)
        if img.mode in ("RGBA", "P", "LA"):
            bg = PILImage.new("RGB", img.size, (255, 255, 255))
            if img.mode == "P":
                img = img.convert("RGBA")
            bg.paste(img, mask=img.split()[-1] if img.mode == "RGBA" else None)
            img = bg
        elif img.mode != "RGB":
            img = img.convert("RGB")
        img.save(dest_path, "JPEG", quality=92)
        return True
    except Exception:
        # Fallback: write raw bytes
        uploaded_file.seek(0)
        with open(dest_path, "wb") as f:
            f.write(uploaded_file.getbuffer())
        return True


class ValuationForm:
    def render(self) -> dict:
        fields = {}

        with st.expander("📋 General Valuation Information", expanded=True):
            fields["a) Identification and status of the valuer"] = st.text_input(
                "a) Identification and status of the valuer")
            fields["b) Client details"] = st.text_input(
                "b) Identification of the client and intended users")
            fields["c) Purpose of the valuation"] = st.text_area("c) Purpose of the valuation")
            fields["d) Identification of the property"] = st.text_area(
                "d) Identification of the asset(s) or liability(ies) valued")
            fields["e) Basis of value adopted"] = st.text_input("e) Basis(es) of value adopted")
            fields["f) Valuation date"] = st.date_input("f) Valuation date")

        with st.expander("🏗️ Property & Valuation Details"):
            fields["g) Nature of the property"] = st.text_area("g) Nature of property")
            fields["h) Site profile"] = st.text_area("h) Site profile (land/building)")

            location_data = self._render_location()
            if location_data:
                fields["Location Address"] = location_data.get("address", "")
                fields["Latitude"]         = location_data.get("lat", "")
                fields["Longitude"]        = location_data.get("lon", "")

            fields["i) Market value evidence"] = st.text_area("i) Evidence of market values")
            fields["j) Assumptions and reservations"] = st.text_area("j) Assumptions and special reservations")
            fields["k) Valuation approach"] = st.text_area("k) Valuation approach and reasoning")
            fields["l) Amount of valuation"] = st.text_input("l) Amount of valuation (LKR)")
            fields["m) Date of report"] = st.date_input("m) Date of the valuation report")

        selected_parts = self._render_property_parts()
        fields["q) Selected Property Parts"] = selected_parts

        property_images = self._render_image_uploads(selected_parts)
        fields["r) Property Images"] = property_images

        self._render_progress(fields)
        return fields

    def _render_location(self) -> dict:
        st.markdown("#### 📍 Property Location (Optional)")
        st.markdown("Search for the property address to pin on map.")

        if "location_data" not in st.session_state:
            st.session_state.location_data = {}

        search_input = st.text_input("Enter property name, address, or city:", key="location_search_input")
        col1, col2 = st.columns([1, 4])
        with col1:
            search_button = st.button("🔍 Find Location", key="search_location")
        with col2:
            if st.session_state.location_data:
                st.success(f"Location: {st.session_state.location_data.get('address', '')}")

        if search_button and search_input:
            with st.spinner("Searching..."):
                try:
                    geolocator = Nominatim(user_agent="propiq_valuation_app")
                    location   = geolocator.geocode(search_input)
                    if location:
                        st.session_state.location_data = {
                            "address": location.address,
                            "lat":     location.latitude,
                            "lon":     location.longitude,
                        }
                        st.success("Location found!")
                    else:
                        st.error("Location not found. Try another name.")
                        st.session_state.location_data = {}
                except Exception as e:
                    st.error(f"Error: {e}")
                    st.session_state.location_data = {}

        if st.session_state.location_data:
            lat = st.session_state.location_data["lat"]
            lon = st.session_state.location_data["lon"]
            map_preview = folium.Map(location=[lat, lon], zoom_start=15)
            folium.Marker(
                [lat, lon],
                popup=f"<a href='https://www.openstreetmap.org/?mlat={lat}&mlon={lon}&zoom=18' target='_blank'>Open Full Map</a>",
                tooltip="Click to open full map",
                icon=folium.Icon(color="red"),
            ).add_to(map_preview)
            st_folium(map_preview, width=600, height=400)
            st.caption(f"Latitude: {lat}, Longitude: {lon}")
            st.info("✅ This location will also be embedded as a map image in the PDF report.")

        return st.session_state.location_data

    def _render_property_parts(self) -> list[str]:
        with st.expander("🏠 Property Details"):
            st.markdown('<div class="section-title">Select Property Parts</div>', unsafe_allow_html=True)
            part_options = ["Living Room", "Bedroom", "Dining Room", "Open Veranda", "Other"]
            checked = {p: st.checkbox(p) for p in part_options}
            other_text = st.text_input("Specify other:", "") if checked.get("Other") else None

        selected = [p for p, v in checked.items() if v and p != "Other"]
        if other_text:
            selected.append(other_text)
        return selected

    def _render_image_uploads(self, selected_parts: list[str]) -> list[PropertyImage]:
        images: list[PropertyImage] = []

        with st.expander("📷 Property Images"):
            st.caption("Accepted formats: JPG, JPEG, PNG")

            main_img = st.file_uploader(
                "Upload main property photo",
                type=["jpg", "jpeg", "png"],
                key="main_img"
            )
            if main_img:
                path = "cover_property.jpg"
                save_uploaded_image(main_img, path)
                images.append(PropertyImage(part="Subject Property", path=path))
                st.image(path, caption="Main Property Photo", width=300)

            if selected_parts:
                for i, part in enumerate(selected_parts, start=1):
                    img = st.file_uploader(
                        f"Upload image for: {part}",
                        type=["jpg", "jpeg", "png"],
                        key=f"img_{i}"
                    )
                    if img:
                        path = f"property_image_{i}.jpg"
                        save_uploaded_image(img, path)
                        images.append(PropertyImage(part=part, path=path))
                        st.image(path, caption=f"{part}", width=300)
            else:
                st.info("Select at least one property part above to upload images.")

        return images

    def _render_progress(self, fields: dict):
        filled = sum(1 for v in fields.values() if v)
        total  = len(fields)
        pct    = int((filled / total) * 100) if total > 0 else 0
        st.progress(pct)
        st.caption(f"Form Completion: {pct}%")



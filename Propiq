class PDFGenerator:
    LOGO_URL = "https://www.sjp.ac.lk/wp-content/uploads/2020/10/usjp-logo-300x300.png"

    TEMPLATES = {
        "01": "The purpose of this valuation is to determine the Market Value of the subject property for the intended purpose as described below.",
        "02": "I inspected the subject property on the date noted below in the presence of the agent of the applicant. The date of inspection is generally accepted as the date of valuation.",
        "03": "Explain how you identify the property. Includes boundary demarcation/plan and deed particulars. Indicate assessment number and postal address wherever applicable.",
        "04": "Explain the use of the property and occupancy: e.g., owner-occupied residential, commercial or industrial property.",
        "05_land": "Explain the geographical features of the land such as shape, terrain, topography, soil condition, elevation, plantation, etc.",
        "05_building": "Describe the building (roof to foundation). Include internal and external features, floor areas, and a pictorial view of each section.",
        "06": "Details of evidence on land values, rentals and cost information collected from reliable sources should be given here.",
        "07": "Assumptions and any special assumptions should be clearly stated. An Assumption is made that a specific investigation is not required to prove something is true.",
        "08": "This explains the meaning of the value figure reported. Examples: Market Value, Forced Sale Value, Insurance Value (derived from IVS).",
        "09": "Explain the selected valuation approach and reasoning. This may be the Market approach, Income approach, or Cost approach.",
        "10": (
            "Prepared by the valuer. The valuation was done according to the standards. "
            "This report is confidential to the client and is not to be used by any other party.\n\n"
            "Yours Sincerely,\n\n{valuer_name}\nChartered Valuation Surveyor\n\n"
            "Date of Report: {date_of_report}\n\n"
            "DISCLAIMER: This template is intended as a general framework only."
        ),
    }

    def generate(self, data: dict, api_key: str) -> str:
        pdf = PDFReport()
        pdf.set_margins(MARGIN, MARGIN, MARGIN)
        pdf.set_auto_page_break(auto=True, margin=18)
        ai_summary = AISummaryGenerator.generate(data, api_key)
        self._build_cover_page(pdf, data)
        pdf.add_page()
        self._build_report_sections(pdf, data, ai_summary)
        report_id = datetime.now().strftime("PROPIQ-%Y%m%d-%H%M%S")
        filename  = f"valuation_report_{report_id}.pdf"
        pdf.output(filename)
        return filename

    # ── cover page ─────────────────────────────────────────────────────────
    def _build_cover_page(self, pdf: PDFReport, data: dict):
        pdf.add_page()

        # Logo
        try:
            pdf.image(self.LOGO_URL, x=(PAGE_W - 35) / 2, y=30, w=35)
        except Exception:
            pass
        pdf.ln(55)

        # Title band
        pdf.set_fill_color(*MAROON)
        pdf.set_text_color(*GOLD)
        pdf.set_font("Arial", "B", 22)
        pdf.cell(CONTENT_W, 14, "VALUATION REPORT", ln=True, fill=True, align="C")
        pdf.ln(6)

        # Valuation amount
        amount = data.get("l) Amount of valuation", "")
        if amount:
            pdf.set_font("Arial", "B", 18)
            pdf.set_text_color(*MAROON)
            pdf.cell(CONTENT_W, 10, f"LKR  {amount}", ln=True, align="C")
        pdf.set_font("Arial", "I", 10)
        pdf.set_text_color(*MID_GRAY)
        pdf.cell(CONTENT_W, 6, "The term of currency is Sri Lankan Rupees", ln=True, align="C")
        pdf.ln(6)

        # Reference / date row
        report_id = datetime.now().strftime("PROPIQ-%Y%m%d-%H%M%S")
        val_date  = data.get("f) Valuation date")
        pdf.set_font("Arial", "", 10)
        pdf.set_text_color(*MID_GRAY)
        pdf.cell(CONTENT_W / 2, 6, f"Reference: {report_id}", ln=False, align="L")
        pdf.cell(CONTENT_W / 2, 6,
                 f"Valuation Date: {val_date.strftime('%d %B %Y') if val_date else 'N/A'}",
                 ln=True, align="R")
        pdf.ln(4)

        # Thin divider
        pdf.set_draw_color(*MAROON)
        pdf.set_line_width(0.4)
        pdf.line(MARGIN, pdf.get_y(), MARGIN + CONTENT_W, pdf.get_y())
        pdf.ln(6)

        # Valuer / client info box
        pdf.set_fill_color(250, 245, 245)
        pdf.set_draw_color(*MAROON)
        pdf.set_line_width(0.3)
        pdf.rect(MARGIN, pdf.get_y(), CONTENT_W, 22, "DF")
        y0 = pdf.get_y() + 4
        pdf.set_xy(MARGIN + 4, y0)
        pdf.set_font("Arial", "B", 9)
        pdf.set_text_color(*MAROON)
        pdf.cell(CONTENT_W / 2 - 4, 5, "PREPARED BY", ln=False)
        pdf.cell(CONTENT_W / 2 - 4, 5, "PREPARED FOR", ln=True)
        pdf.set_x(MARGIN + 4)
        pdf.set_font("Arial", "", 9)
        pdf.set_text_color(*DARK_GRAY)
        valuer  = data.get("a) Identification and status of the valuer", "N/A")
        client  = data.get("b) Client details", "N/A")
        pdf.cell(CONTENT_W / 2 - 4, 5,
                 valuer[:55] + ("..." if len(valuer) > 55 else ""), ln=False)
        pdf.cell(CONTENT_W / 2 - 4, 5,
                 client[:55] + ("..." if len(client) > 55 else ""), ln=True)
        pdf.ln(16)

        # Main property image (centred, max 140 mm wide)
        images: list[PropertyImage] = data.get("r) Property Images", [])
        if images and images[0].exists():
            pdf.embed_image(images[0].path, caption="Subject Property", max_w=140)

    # ── report sections ────────────────────────────────────────────────────
    def _build_report_sections(self, pdf: PDFReport, data: dict, ai_summary: str = ""):
        t = self.TEMPLATES

        pdf.section_heading("01.0  PURPOSE OF VALUATION")
        pdf.field_block(t["01"], data.get("c) Purpose of the valuation"))
        pdf.divider()

        pdf.section_heading("02.0  DATE OF INSPECTION")
        val_date = data.get("f) Valuation date")
        pdf.field_block(t["02"], val_date.strftime("%d %B %Y") if val_date else None)
        pdf.divider()

        pdf.section_heading("03.0  IDENTIFICATION OF PROPERTY")
        pdf.field_block(t["03"], data.get("d) Identification of the property"))
        pdf.divider()

        pdf.section_heading("04.0  NATURE OF PROPERTY")
        pdf.field_block(t["04"], data.get("g) Nature of the property"))
        pdf.divider()

        pdf.section_heading("05.0  SITE PROFILE")
        pdf.sub_heading("05.1  Land")
        pdf.field_block(t["05_land"], data.get("h) Site profile"))
        pdf.sub_heading("05.2  Building")
        pdf.field_block(t["05_building"], None)

        # Property part images (skip cover image — already on cover)
        images: list[PropertyImage] = data.get("r) Property Images", [])
        for img in images[1:]:
            if img.exists():
                pdf.embed_image(img.path, caption=img.part, max_w=155)

        # Location map
        self._insert_location_map(pdf, data)
        pdf.divider()

        pdf.section_heading("06.0  EVIDENCE OF MARKET VALUES")
        pdf.field_block(t["06"], data.get("i) Market value evidence"))
        pdf.divider()

        pdf.section_heading("07.0  ASSUMPTION AND RESERVATION")
        pdf.field_block(t["07"], data.get("j) Assumptions and reservations"))
        pdf.divider()

        pdf.section_heading("08.0  BASIS OF VALUATION")
        pdf.field_block(t["08"], data.get("e) Basis of value adopted"))
        pdf.divider()

        pdf.section_heading("09.0  VALUATION APPROACH AND REASONING")
        pdf.field_block(t["09"], data.get("k) Valuation approach"))
        pdf.divider()

        pdf.section_heading("10.0  CERTIFICATE")
        valuer       = data.get("a) Identification and status of the valuer", "__________")
        rep_date     = data.get("m) Date of the valuation report")
        rep_date_str = rep_date.strftime("%d %B %Y") if rep_date else "__________"
        cert_text    = t["10"].format(valuer_name=valuer, date_of_report=rep_date_str)
        for line in cert_text.split("\n"):
            pdf.set_font("Arial", "", 10)
            pdf.set_text_color(*DARK_GRAY)
            pdf.multi_cell(CONTENT_W, 6, line.strip())
        pdf.ln(4)

        # ── Section 11: AI Summary ────────────────────────────────────────
        pdf.add_page()
        pdf.section_heading("11.0  PROPERTY SUMMARY")
        pdf.guidance_text(
            "The following summary has been automatically generated by Google Gemini AI based on all "
            "information entered in this valuation report. It consolidates and presents the key "
            "details across all sections in a professional narrative format."
        )
        pdf.ln(2)
        if ai_summary:
            pdf.summary_box(ai_summary)
        else:
            pdf.user_value("No summary available.")

        pdf.ln(4)
        pdf.set_font("Arial", "B", 9)
        pdf.set_text_color(*MAROON)
        pdf.cell(CONTENT_W, 6,
                 f"Generated on: {datetime.now().strftime('%d %B %Y  %H:%M:%S')}",
                 ln=True, align="R")

    # ── location map ───────────────────────────────────────────────────────
    def _insert_location_map(self, pdf: PDFReport, data: dict):
        try:
            from PIL import Image as PILImage, ImageDraw
        except ImportError:
            return

        lat     = data.get("Latitude")
        lon     = data.get("Longitude")
        address = data.get("Location Address", "")
        if not lat or not lon:
            return

        pdf.sub_heading("05.3  Property Location Map")
        pdf.set_text_color(*MID_GRAY)
        pdf.set_font("Arial", "", 9)
        if address:
            safe = address.encode("latin-1", errors="replace").decode("latin-1")
            pdf.multi_cell(CONTENT_W, 5, f"Address: {safe}")
        pdf.multi_cell(CONTENT_W, 5, f"Coordinates: {lat:.6f} N,  {lon:.6f} E")
        pdf.ln(3)

        zoom      = 15
        tile_size = 256
        grid      = 3

        def deg2tile(la, lo, z):
            n  = 2 ** z
            tx = int((lo + 180.0) / 360.0 * n)
            ty = int((1.0 - math.asinh(math.tan(math.radians(la))) / math.pi) / 2.0 * n)
            return tx, ty

        def coord2px(la, lo, z, ox, oy):
            n  = 2 ** z
            px = (lo + 180.0) / 360.0 * n * tile_size - ox * tile_size
            py = (1.0 - math.asinh(math.tan(math.radians(la))) / math.pi) / 2.0 * n * tile_size - oy * tile_size
            return int(px), int(py)

        cx, cy = deg2tile(lat, lon, zoom)
        half   = grid // 2
        canvas = PILImage.new("RGB", (tile_size * grid, tile_size * grid), (210, 210, 210))
        hdrs   = {"User-Agent": "PROPIQ-ValuationApp/1.0"}

        for row in range(grid):
            for col in range(grid):
                url = f"https://tile.openstreetmap.org/{zoom}/{cx-half+col}/{cy-half+row}.png"
                try:
                    r = requests.get(url, headers=hdrs, timeout=10)
                    if r.status_code == 200:
                        tile = PILImage.open(io.BytesIO(r.content)).convert("RGB")
                        canvas.paste(tile, (col * tile_size, row * tile_size))
                except Exception:
                    pass

        # Marker
        px, py = coord2px(lat, lon, zoom, cx - half, cy - half)
        draw   = ImageDraw.Draw(canvas)
        for radius, colour in [(14, MAROON), (10, (220, 30, 30)), (4, WHITE)]:
            draw.ellipse([px - radius, py - radius, px + radius, py + radius], fill=colour)
        draw.rectangle([0, 0, canvas.width-1, canvas.height-1], outline=MAROON, width=4)

        map_path = "location_map_pdf.png"
        canvas.save(map_path)

        try:
            w = CONTENT_W
            pdf.image(map_path, x=MARGIN, y=None, w=w)
            pdf.ln(2)
            pdf.set_font("Arial", "I", 8)
            pdf.set_text_color(*LIGHT_GRAY)
            pdf.cell(CONTENT_W, 5, "Map data (c) OpenStreetMap contributors", ln=True, align="C")
            pdf.ln(3)
        except Exception as e:
            pdf.guidance_text(f"Map could not be rendered: {e}")
        finally:
            try:
                os.remove(map_path)
            except Exception:
                pass

    def cleanup(self, pdf_path: str, images: list[PropertyImage]):
        try:
            os.remove(pdf_path)
        except Exception:
            pass
        for img in images:
            img.remove()



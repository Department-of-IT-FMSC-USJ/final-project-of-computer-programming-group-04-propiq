class DashboardPage:
    def __init__(self, pdf_generator: PDFGenerator):
        self.form          = ValuationForm()
        self.api_widget    = APIKeyWidget()
        self.pdf_generator = pdf_generator

    def render(self):
        username = SessionManager.get("username")
        st.markdown(f"<h3 style='color:#800000;'>Welcome, {username}! 👋</h3>",
                    unsafe_allow_html=True)
        api_key = self.api_widget.render()

        st.markdown('<div class="card">', unsafe_allow_html=True)
        st.markdown('<div class="section-title">Valuation Report Form</div>',
                    unsafe_allow_html=True)
        fields = self.form.render()

        if st.button("📄 Generate PDF Report", use_container_width=True):
            if not api_key or len(api_key) < 10:
                st.error("⚠️ Please enter your Google Gemini API key above before generating.")
            else:
                self._handle_pdf_generation(fields, api_key)
        st.markdown("</div>", unsafe_allow_html=True)

    def _handle_pdf_generation(self, fields: dict, api_key: str):
        with st.spinner("✨ Generating AI property summary and building your report..."):
            pdf_path = self.pdf_generator.generate(fields, api_key)

        with open(pdf_path, "rb") as f:
            pdf_bytes = f.read()
            b64 = base64.b64encode(pdf_bytes).decode("utf-8")

        st.success("✅ Report generated successfully!")

        with st.expander("📑 Preview Generated PDF", expanded=True):
            st.markdown(
                f'<iframe src="data:application/pdf;base64,{b64}" '
                f'width="100%" height="750"></iframe>',
                unsafe_allow_html=True,
            )

        st.download_button(
            label="⬇️ Download Valuation Report PDF",
            data=pdf_bytes,
            file_name=os.path.basename(pdf_path),
            mime="application/pdf",
            use_container_width=True,
        )
        images: list[PropertyImage] = fields.get("r) Property Images", [])
        self.pdf_generator.cleanup(pdf_path, images)



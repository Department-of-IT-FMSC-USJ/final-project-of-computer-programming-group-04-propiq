PAGE_W      = 210   # A4 width mm
PAGE_H      = 297   # A4 height mm
MARGIN      = 15    # page margin mm
CONTENT_W   = PAGE_W - 2 * MARGIN   # 180 mm usable width

MAROON      = (128, 0, 0)
GOLD        = (255, 215, 0)
DARK_GRAY   = (50, 50, 50)
MID_GRAY    = (100, 100, 100)
LIGHT_GRAY  = (150, 150, 150)
CREAM_BG    = (255, 248, 220)
WHITE       = (255, 255, 255)


class PDFReport(FPDF):

    # ── page chrome ────────────────────────────────────────────────────────
    def header(self):
        self.set_fill_color(*MAROON)
        self.rect(0, 0, PAGE_W, 18, "F")
        self.set_text_color(*GOLD)
        self.set_font("Arial", "B", 13)
        self.set_y(4)
        self.cell(0, 10, "PROPIQ  |  University of Sri Jayewardenepura", ln=True, align="C")
        self.ln(6)

    def footer(self):
        self.set_y(-13)
        self.set_fill_color(*MAROON)
        self.rect(0, PAGE_H - 13, PAGE_W, 13, "F")
        self.set_text_color(*GOLD)
        self.set_font("Arial", "I", 9)
        self.cell(0, 10, f"Generated by PROPIQ | USJP   |   Page {self.page_no()}", 0, 0, "C")

    # ── reusable drawing helpers ───────────────────────────────────────────
    def section_heading(self, title: str):
        """Full-width maroon band with white heading text."""
        self.set_fill_color(*MAROON)
        self.set_text_color(*WHITE)
        self.set_font("Arial", "B", 11)
        self.cell(CONTENT_W, 8, f"  {title}", ln=True, fill=True)
        self.ln(2)
        self.set_text_color(*DARK_GRAY)

    def sub_heading(self, title: str):
        """Lighter sub-section heading with left accent bar."""
        self.set_fill_color(200, 180, 180)
        self.rect(MARGIN, self.get_y(), 2, 6, "F")
        self.set_x(MARGIN + 4)
        self.set_text_color(*MAROON)
        self.set_font("Arial", "B", 10)
        self.cell(CONTENT_W - 4, 6, title, ln=True)
        self.ln(1)
        self.set_text_color(*DARK_GRAY)

    def guidance_text(self, text: str):
        """Small italic grey guidance/template text."""
        self.set_text_color(*MID_GRAY)
        self.set_font("Arial", "I", 9)
        for line in text.split("\n"):
            self.multi_cell(CONTENT_W, 5, line.strip())
        self.ln(1)

    def user_value(self, value):
        """Bold black user-entered value, or light-grey N/A."""
        if value and str(value).strip() and str(value).strip() != "N/A":
            self.set_text_color(*DARK_GRAY)
            self.set_font("Arial", "B", 10)
            text = ", ".join(value) if isinstance(value, list) else str(value)
            self.multi_cell(CONTENT_W, 6, text)
        else:
            self.set_text_color(*LIGHT_GRAY)
            self.set_font("Arial", "I", 9)
            self.cell(CONTENT_W, 6, "N/A", ln=True)
        self.ln(3)
        self.set_text_color(*DARK_GRAY)

    def field_block(self, guidance: str, value):
        """Render a guidance line followed by the user's answer."""
        self.guidance_text(guidance)
        self.user_value(value)

    def divider(self):
        self.set_draw_color(*MAROON)
        self.set_line_width(0.2)
        self.line(MARGIN, self.get_y(), MARGIN + CONTENT_W, self.get_y())
        self.ln(3)

    def embed_image(self, path: str, caption: str = "", max_w: int = 160):
        """Embed an image centred on the page with optional caption."""
        try:
            from PIL import Image as PILImage
            with PILImage.open(path) as im:
                iw, ih = im.size
            aspect = ih / iw
            w = min(max_w, CONTENT_W)
            h = w * aspect
            # ensure it fits on remaining page
            if self.get_y() + h + 10 > PAGE_H - 20:
                self.add_page()
            x = MARGIN + (CONTENT_W - w) / 2
            self.image(path, x=x, y=None, w=w)
            if caption:
                self.set_font("Arial", "I", 8)
                self.set_text_color(*MID_GRAY)
                self.cell(CONTENT_W, 5, caption, ln=True, align="C")
            self.ln(4)
        except Exception:
            self.set_font("Arial", "I", 9)
            self.set_text_color(*LIGHT_GRAY)
            self.cell(CONTENT_W, 6, f"[Image unavailable: {caption}]", ln=True)
            self.ln(2)

    def summary_box(self, text: str):
        """Cream-coloured box for the AI summary."""
        self.set_fill_color(*CREAM_BG)
        self.set_draw_color(*MAROON)
        self.set_line_width(0.4)
        lines_est = max(10, len(text) // 90 + 2)
        box_h = lines_est * 5.5 + 18
        box_y = self.get_y()
        if box_y + box_h > PAGE_H - 20:
            self.add_page()
            box_y = self.get_y()
        self.rect(MARGIN, box_y, CONTENT_W, box_h, "DF")
        self.set_xy(MARGIN + 4, box_y + 5)
        self.set_text_color(*MAROON)
        self.set_font("Arial", "B", 10)
        self.cell(0, 6, "AI-Generated Property Summary  (Google Gemini)", ln=True)
        self.ln(1)
        self.set_x(MARGIN + 4)
        self.set_text_color(30, 30, 30)
        self.set_font("Arial", "", 9)
        self.multi_cell(CONTENT_W - 8, 5.2, text)
        self.ln(5)


